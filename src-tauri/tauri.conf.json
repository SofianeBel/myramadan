{
  "productName": "GuideME - Ramadan",
  "version": "1.6.0",
  "identifier": "com.guideme.ramadan",
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/SofianeBel/myramadan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREOTUwOUFDMEFFNThCMTQKUldRVWkrVUtyQW1WVFg0WlBnaDdzeHc0eDZyL1hpVlNTN2Z0VmJqMUt3NUFwRm5kMWxsMUl2K2UK"
    }
  },
  "app": {
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost https://api.aladhan.com https://github.com https://objects.githubusercontent.com",
        "media-src": "'self'",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com",
        "img-src": "'self' https://*.tile.openstreetmap.org data: blob:",
        "font-src": "'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com data:"
      }
    },
    "windows": [
      {
        "title": "GuideME - Ramadan Edition",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ]
  }
}