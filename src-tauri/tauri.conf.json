{
  "productName": "GuideME - Ramadan",
  "version": "1.0.0",
  "identifier": "com.guideme.ramadan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost https://api.aladhan.com",
        "media-src": "'self'",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com",
        "img-src": "'self' https://*.tile.openstreetmap.org data: blob:",
        "font-src": "'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com data:"
      }
    },
    "windows": [
      {
        "title": "GuideME - Ramadan Edition",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ]
  }
}
